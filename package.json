{
  "name": "writelynx-workspace",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/even7hq/writelynx.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspace writelynx build && yarn build:lua-builtin",
    "build:builtin": "node scripts/compose-builtin-rules.mjs",
    "build:lua-builtin": "node scripts/sync-builtin-to-lua.mjs",
    "test": "yarn workspace writelynx test && yarn workspace @writelynx/lua test",
    "test:js": "yarn workspace writelynx test",
    "test:lua": "yarn workspace @writelynx/lua test",
    "docs:dev": "yarn workspace @writelynx/docs dev",
    "docs:build": "yarn workspace @writelynx/docs build"
  }
}
