{
  "name": "writelynx",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Configurable validation and redaction engine for sensitive data",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/even7hq/writelynx.git",
    "directory": "packages/js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "writelynx": "./dist/cli/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@writelynx/builtin-rules": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  }
}
